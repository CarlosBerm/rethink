# Optional — compartment ID is auto-fetched from instance metadata if not set
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxx

PORT=3000

# Shared bearer token — set the same value in both .env and extension/background.js
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your-strong-random-secret-here

# Your Chrome extension ID — found at chrome://extensions after loading unpacked
# When set, CORS is locked to only your extension (recommended)
ALLOWED_EXTENSION_ID=your-extension-id-here
